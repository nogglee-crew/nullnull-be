generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum RoomStatus {
  COLLECTING
  READY
  CONFIRMED
  CLOSED
}

enum RoomCategory {
  MEAL
  CAFE
  DRINK
  STUDY
  MEETING
  EXERCISE
  GAME
  PARTY
  ETC
}

enum ParticipantRole {
  HOST
  MEMBER
}

enum ParticipantStatus {
  JOINED
  SUBMITTED
  DECLINED
}

model User {
  userId    BigInt   @id @default(autoincrement()) @map("user_id")
  nickname  String   @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  auth         Auth?
  ownedRooms   Room[]
  participants Participant[]

  @@map("users")
}

model Auth {
  authId       BigInt   @id @default(autoincrement()) @map("auth_id")
  userId       BigInt   @unique @map("user_id")
  kakaoUserId  String   @unique @map("kakao_user_id") @db.VarChar(100)
  refreshToken String   @map("refresh_token") @db.VarChar(500)
  expiresAt    DateTime @map("expires_at")

  user User @relation(fields: [userId], references: [userId])

  @@map("auth")
}

model Room {
  roomId        BigInt       @id @default(autoincrement()) @map("room_id")
  ownerId       BigInt       @map("owner_id")
  slug          String       @unique @db.VarChar(50)
  name          String       @db.VarChar(50)
  description   String?      @db.VarChar(500)
  status        RoomStatus   @default(COLLECTING)
  category      RoomCategory @default(MEAL)
  dateStart     DateTime     @map("date_start") @db.Date
  dateEnd       DateTime     @map("date_end") @db.Date
  availableDays Int[]        @map("available_days")
  timeStart     DateTime     @map("time_start") @db.Time(0)
  timeEnd       DateTime     @map("time_end") @db.Time(0)
  deadlineAt    DateTime     @map("deadline_at")
  collectOrigin Boolean      @default(false) @map("collect_origin")
  createdAt     DateTime     @default(now()) @map("created_at")

  owner        User          @relation(fields: [ownerId], references: [userId])
  participants Participant[]
  timeOptions  TimeOption[]
  placeOptions PlaceOption[]
  meeting      Meeting?
  closure      Closure?

  @@map("rooms")
}

model Participant {
  participantId BigInt            @id @default(autoincrement()) @map("participant_id")
  roomId        BigInt            @map("room_id")
  userId        BigInt?           @map("user_id")
  role          ParticipantRole   @default(MEMBER)
  status        ParticipantStatus @default(JOINED)
  nickname      String            @db.VarChar(50)
  decisionAt    DateTime?         @map("decision_at")
  createdAt     DateTime          @default(now()) @map("created_at")

  room         Room          @relation(fields: [roomId], references: [roomId])
  user         User?         @relation(fields: [userId], references: [userId])
  origin       Origin?
  blockedSlots BlockedSlot[]

  @@map("participants")
}

enum ClosureFromStatus {
  COLLECTING
  READY
  CONFIRMED
}

enum ClosureTrigger {
  MANUAL
  EXPIRED
  REACHED
}

model Origin {
  originId      BigInt  @id @default(autoincrement()) @map("origin_id")
  participantId BigInt  @unique @map("participant_id")
  latitude      Decimal @db.Decimal(10, 7)
  longitude     Decimal @db.Decimal(10, 7)
  address       String  @db.VarChar(500)
  placeName     String? @map("place_name") @db.VarChar(100)

  participant Participant @relation(fields: [participantId], references: [participantId])

  @@map("origins")
}

model BlockedSlot {
  blockedSlotId BigInt   @id @default(autoincrement()) @map("blocked_slot_id")
  participantId BigInt   @map("participant_id")
  date          DateTime @db.Date
  slotIndex     Int      @map("slot_index")
  createdAt     DateTime @default(now()) @map("created_at")

  participant Participant @relation(fields: [participantId], references: [participantId])

  @@unique([participantId, date, slotIndex])
  @@index([participantId])
  @@index([date])
  @@map("blocked_slots")
}

model TimeOption {
  timeOptionId    BigInt   @id @default(autoincrement()) @map("time_option_id")
  roomId          BigInt   @map("room_id")
  startAt         DateTime @map("start_at")
  endAt           DateTime @map("end_at")
  availableCount  Int      @map("available_count")
  durationMinutes Int      @map("duration_minutes")
  rank            Int

  room     Room      @relation(fields: [roomId], references: [roomId])
  meetings Meeting[]

  @@unique([roomId, rank])
  @@map("time_options")
}

model PlaceOption {
  placeOptionId   BigInt  @id @default(autoincrement()) @map("place_option_id")
  roomId          BigInt  @map("room_id")
  placeName       String  @map("place_name") @db.VarChar(100)
  latitude        Decimal @db.Decimal(10, 7)
  longitude       Decimal @db.Decimal(10, 7)
  address         String  @db.VarChar(500)
  averageDistance Int     @map("average_distance")
  totalDistance   Int     @map("total_distance")
  score           Int
  rank            Int

  room     Room      @relation(fields: [roomId], references: [roomId])
  meetings Meeting[]

  @@unique([roomId, rank])
  @@map("place_options")
}

model Meeting {
  meetingId     BigInt   @id @default(autoincrement()) @map("meeting_id")
  roomId        BigInt   @unique @map("room_id")
  timeOptionId  BigInt   @map("time_option_id")
  placeOptionId BigInt?  @map("place_option_id")
  createdAt     DateTime @default(now()) @map("created_at")

  room        Room         @relation(fields: [roomId], references: [roomId])
  timeOption  TimeOption   @relation(fields: [timeOptionId], references: [timeOptionId])
  placeOption PlaceOption? @relation(fields: [placeOptionId], references: [placeOptionId])

  @@map("meetings")
}

model Closure {
  closureId        BigInt            @id @default(autoincrement()) @map("closure_id")
  roomId           BigInt            @unique @map("room_id")
  closedFromStatus ClosureFromStatus @map("closed_from_status")
  closeTrigger     ClosureTrigger    @map("close_trigger")
  closedAt         DateTime          @default(now()) @map("closed_at")

  room Room @relation(fields: [roomId], references: [roomId])

  @@map("closures")
}
