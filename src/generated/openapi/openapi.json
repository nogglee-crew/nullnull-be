          },
          "message": {
            "type": "string",
            "example": "요청이 성공적으로 처리되었습니다."
          },
          "error": {
            "type": "string",
            "example": null,
            "nullable": true
          },
          "data": {
            "$ref": "#/components/schemas/AuthSyncDataDto"
          }
        },
        "required": [
